# Veripraxis Mock Exam - .gitignore

# ==============================================
# Dependencies
# ==============================================
node_modules/
.pnp
.pnp.js

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ==============================================
# Next.js
# ==============================================
.next/
out/
dist/
build/

# ==============================================
# Environment Variables
# ==============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==============================================
# Testing
# ==============================================
coverage/
.nyc_output/
*.lcov
.pytest_cache/

# ==============================================
# Logs
# ==============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==============================================
# OS Files
# ==============================================
.DS_Store
*.swp
*.swo
*~
Thumbs.db
Desktop.ini

# ==============================================
# IDE
# ==============================================
.vscode/
.idea/
*.sublime-*
*.iml

# ==============================================
# Temporary Files
# ==============================================
tmp/
temp/
*.tmp
*.temp

# ==============================================
# Build Files
# ==============================================
*.tsbuildinfo
next-env.d.ts

# ==============================================
# Uploads & User Data (DO NOT COMMIT)
# ==============================================
uploads/
user-data/
*.xlsx
*.xls
*.pdf
!public/**/*.pdf

# ==============================================
# Supabase
# ==============================================
.branches/
.supabase/

# ==============================================
# Mobile (React Native / Expo)
# ==============================================
.expo/
.expo-shared/

# ==============================================
# Package Manager
# ==============================================
.pnpm-store/
.yarn/